<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ToDoList.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ToDoList.Pages"
    Title="ToDoList"
    NavBarIsVisible="False">

    <ShellContent
        ContentTemplate="{DataTemplate local:SignInPage}"
        Route="SignInPage" />
    
    <ShellContent
        ContentTemplate="{DataTemplate local:SignUpPage}"
        Route="SignUpPage" />

    <TabBar Route="main">
        <Tab Title="To-Do">
            <ShellContent ContentTemplate="{DataTemplate local:ToDoPage}" Route="ToDoPage" />
        </Tab>
        <Tab Title="Completed">
             <ShellContent ContentTemplate="{DataTemplate local:CompletedPage}" Route="CompletedPage" />
        </Tab>
        <Tab Title="Profile">
            <ShellContent ContentTemplate="{DataTemplate local:ProfilePage}" Route="ProfilePage" />
        </Tab>
    </TabBar>

</Shell>